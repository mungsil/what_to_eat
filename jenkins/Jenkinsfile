pipeline {
        agent {
    kubernetes {
        yaml """
apiVersion: v1
kind: Pod
spec:
  hostUsers: false
  containers:
  - name: buildah
    image: quay.io/buildah/stable
    command: ['sleep', 'infinity']
    securityContext:
      runAsUser: 1000
      runAsGroup: 1000
    volumeMounts:
    - name: storage
      mountPath: /storage
    - name: storage-conf
      mountPath: /etc/containers/
  volumes:
  - name: storage
    emptyDir:
      sizeLimit: 8Gi
  - name: storage-conf
    configMap:
      name: storage-conf
"""
    }
}

    options {
        buildDiscarder(logRotator(
            numToKeepStr: '10',
            artifactNumToKeepStr: '3'
        ))
    }

    environment {
        GHCR_REGISTRY = 'ghcr.io'
        GITHUB_USER = 'mungsil'
        IMAGE_NAME = 'what-to-eat'
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'master',
                    credentialsId: 'github-credentials',
                    url: 'https://github.com/mungsil/what_to_eat.git'
            }
        }

        stage('Build and Push Image') {
            steps {
                container('buildah') { 
                    withCredentials([usernamePassword(
                        credentialsId: 'github-credentials',
                        usernameVariable: 'GHCR_USER',
                        passwordVariable: 'GHCR_TOKEN'
                    )]) {
                        sh '''
                            buildah login $GHCR_REGISTRY -u $GHCR_USER -p $GHCR_TOKEN
                            buildah bud -t $GHCR_REGISTRY/$GHCR_USER/$IMAGE_NAME:$IMAGE_TAG .
                            buildah push $GHCR_REGISTRY/$GHCR_USER/$IMAGE_NAME:$IMAGE_TAG
                            buildah rmi $GHCR_REGISTRY/$GHCR_USER/$IMAGE_NAME:$IMAGE_TAG
                        '''
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                    kubectl set image deployment/whatToEat-spring-boot \
                        whatToEat-spring-boot=$GHCR_REGISTRY/$GITHUB_USER/$IMAGE_NAME:$IMAGE_TAG
                    kubectl rollout status deployment/whatToEat-spring-boot
                '''
            }
        }
    }

    post {
        failure {
            echo 'Pipeline failed'
        }
        success {
            echo 'Pipeline successfully completed'
        }
    }
}