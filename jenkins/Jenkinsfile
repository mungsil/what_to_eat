pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  serviceAccountName: jenkins-robot
  securityContext:
    runAsUser: 1000
    runAsGroup: 1000
  imagePullSecrets:
  - name: dhi-pull-secret
  containers:
  - name: jdk
    image: eclipse-temurin:17-jdk
    command: ['sleep', 'infinity']
    securityContext:
      runAsUser: 0
      runAsGroup: 0
    volumeMounts:
    - name: gradle-cache
      mountPath: /gradle-cache
  - name: buildah
    image: quay.io/buildah/stable
    command: ['sleep', 'infinity']
    securityContext:
      privileged: true
      runAsUser: 0
      runAsGroup: 0
    volumeMounts:
    - name: storage
      mountPath: /var/lib/containers/storage
  - name: kubectl
    image: dhi.io/kubectl:1-compat
    command: ['sleep', 'infinity']
  volumes:
  - name: storage
    persistentVolumeClaim:
      claimName: buildah-pvc-new
  - name: gradle-cache
    persistentVolumeClaim:
      claimName: gradle-cache-pvc
"""
        }
    }

    options {
        buildDiscarder(logRotator(
            numToKeepStr: '10',
            artifactNumToKeepStr: '3'
        ))
    }

    environment {
        GHCR_REGISTRY = 'ghcr.io'
        GITHUB_USER = 'mungsil'
        IMAGE_NAME = 'what-to-eat'
        IMAGE_TAG = "${BUILD_NUMBER}"
        GRADLE_USER_HOME = '/gradle-cache'
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'master',
                    credentialsId: 'github-credentials',
                    url: 'https://github.com/mungsil/what_to_eat.git'
            }
        }

        stage('Gradle Build') {
            steps {
                container('jdk') {
                    sh '''
                        chmod +x ./gradlew
                        ./gradlew clean build -x test --no-daemon
                    '''
                }
            }
        }

        stage('Build and Push Image') {
            steps {
                container('buildah') {
                    withCredentials([usernamePassword(
                        credentialsId: 'github-credentials',
                        usernameVariable: 'GHCR_USER',
                        passwordVariable: 'GHCR_TOKEN'
                    )]) {
                        sh '''
                            # 이전 빌드 잔여물 선정리
                            buildah rm --all || true

                            buildah login $GHCR_REGISTRY -u $GHCR_USER -p $GHCR_TOKEN
                            buildah bud --layers=true -t $GHCR_REGISTRY/$GHCR_USER/$IMAGE_NAME:$IMAGE_TAG .
                            buildah push $GHCR_REGISTRY/$GHCR_USER/$IMAGE_NAME:$IMAGE_TAG
                            buildah rmi $GHCR_REGISTRY/$GHCR_USER/$IMAGE_NAME:$IMAGE_TAG
                        '''
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                container('kubectl') {
                    withKubeConfig([namespace: "what-to-eat"]) {
                        sh '''
                            kubectl set image deployment/wte-spring \
                                wte-spring=$GHCR_REGISTRY/$GITHUB_USER/$IMAGE_NAME:$IMAGE_TAG
                            kubectl rollout status deployment/wte-spring
                        '''
                    }
                }
            }
        }
    }

    post {
        always {
            container('buildah') {
                sh 'buildah rm --all || true'
            }
        }
        failure {
            echo 'Pipeline failed'
        }
        success {
            echo 'Pipeline successfully completed'
        }
    }
}